{
  "version": 3,
  "overrides": {
    "about/index.html": {
      "path": "about"
    },
    "services/index.html": {
      "path": "services"
    },
    "contact/index.html": {
      "path": "contact"
    },
    "news/index.html": {
      "path": "news"
    },
    "index.html": {
      "path": ""
    },
    "faq/index.html": {
      "path": "faq"
    },
    "products/index.html": {
      "path": "products"
    },
    "product-category/index.html": {
      "path": "product-category"
    }
  },
  "routes": [
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/builds/meta/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=1, immutable"
      },
      "src": "/_nuxt/builds/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/(.*)"
    },
    {
      "src": "/_nuxt/builds/meta(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt/builds(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "(?<url>/__nuxt_error)",
      "dest": "/__fallback"
    },
    {
      "src": "/test",
      "dest": "/test"
    },
    {
      "src": "/services",
      "dest": "/services"
    },
    {
      "src": "/references",
      "dest": "/references"
    },
    {
      "src": "/profiles",
      "dest": "/profiles"
    },
    {
      "src": "/products",
      "dest": "/products"
    },
    {
      "src": "/product-detail",
      "dest": "/product-detail"
    },
    {
      "src": "/product-category",
      "dest": "/product-category"
    },
    {
      "src": "/news-detail",
      "dest": "/news-detail"
    },
    {
      "src": "/news",
      "dest": "/news"
    },
    {
      "src": "/faq",
      "dest": "/faq"
    },
    {
      "src": "/contact",
      "dest": "/contact"
    },
    {
      "src": "/api/site-config",
      "dest": "/api/site-config"
    },
    {
      "src": "/api/menu",
      "dest": "/api/menu"
    },
    {
      "src": "/api/footer",
      "dest": "/api/footer"
    },
    {
      "src": "/about",
      "dest": "/about"
    },
    {
      "src": "/__nuxt_error",
      "dest": "/__nuxt_error"
    },
    {
      "src": "/",
      "dest": "/index"
    },
    {
      "src": "/_ipx/(?:.*)",
      "dest": "/_ipx/[...]"
    },
    {
      "src": "/__nuxt_island/(?:.*)",
      "dest": "/__nuxt_island/[...]"
    },
    {
      "src": "/(.*)",
      "dest": "/__fallback"
    }
  ]
}